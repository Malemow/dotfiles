[global]
    monitor = 0
    follow = mouse

    # 位置與大小
    origin = top-right
    offset = (20, 20)
    width = 300
    notification_limit = 20

    # 外觀
    corner_radius = 10
    frame_width = 2
    gap_size = 5
    separator_height = 1
    separator_color = auto
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 10

    # 字型
    font = JetBrainsMono Nerd Font 10

    # 文字格式
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    line_height = 2
    ellipsize = middle
    ignore_newline = no
    show_indicators = no

    # Icon
    icon_position = left
    min_icon_size = 48
    max_icon_size = 64
    icon_corner_radius = 5
    enable_recursive_icon_lookup = true
    icon_theme = "Tela-circle-dracula, hicolor"

    # Progress bar
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 250
    progress_bar_corner_radius = 4

    # 歷史
    sticky_history = yes
    history_length = 20

    # 行為
    sort = yes
    stack_duplicates = true
    hide_duplicate_count = false
    show_age_threshold = 60
    browser = /usr/bin/xdg-open
    always_run_script = true
    dmenu = /usr/bin/rofi -dmenu -p dunst

    # 滑鼠操作
    mouse_left_click = context, close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    # Wayland
    force_xwayland = false
    layer = overlay

[experimental]
    per_monitor_dpi = true

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#313244"
    timeout = 4

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 6

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0
